# Application Settings
APP_NAME="Food & Nutrition Analysis API"
APP_VERSION=0.1.0
DEBUG=True

# API Configuration
API_V1_PREFIX=/api/v1

# Database Configuration
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/foodai_db

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# AI Service Configuration
AI_SERVICE_URL=http://localhost:8001

# Gemini AI Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: model id (see Google AI Studio), e.g. gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Local YOLO Model Configuration
# Path to the trained YOLO weights file (relative to the backend/ directory, or absolute)
YOLO_MODEL_PATH=../best.pt
YOLO_CONFIDENCE_THRESHOLD=0.4
